# Copy this file to .env and fill in real values. Never commit .env.

# IGDB (games database) credentials. IGDB is owned by Twitch, so these come from
# a Twitch app: https://dev.twitch.tv/console/apps -> Register Your Application.
# The Client ID is shown on the app; "New Secret" generates the Client Secret.
# Server-side only. Read by the Vercel API routes; never sent to the browser.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Neon Postgres connection string - from https://neon.tech (use the "pooled" one)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign session cookies (JWT, HS256). MUST be at least 32 characters.
# Generate one with:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this signs everyone out. Use a DIFFERENT value in production than in dev.
AUTH_SECRET=
