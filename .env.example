# Copy this file to .env and fill in real values. Never commit .env.

# RAWG Video Games API key - free key from https://rawg.io/apidocs
# Server-side only. This is read by the Vercel API routes, never by the browser.
RAWG_API_KEY=

# Neon Postgres connection string - from https://neon.tech (use the "pooled" connection string)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
